CONFIG_STATIC=y
CONFIG_CTTYHACK=y
CONFIG_FEATURE_PREFER_APPLETS=y
CONFIG_FEATURE_SH_STANDALONE=y
CONFIG_CAT=y
# Deterministic guest-side virtio-rng verification needs one bounded seeded read, one hex dump, and a bounded wait.
CONFIG_DD=y
CONFIG_MKDIR=y
CONFIG_MKNOD=y
CONFIG_MOUNT=y
CONFIG_OD=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y
CONFIG_SH_IS_ASH=y
CONFIG_SLEEP=y
CONFIG_ASH=y
# CONFIG_TC is not set